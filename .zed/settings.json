{
  "preferred_line_length": 100,
  "wrap_guides": [100],

  "languages": {
    "Astro": {
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": ["biome", "astro-language-server", "tailwindcss-language-server"]
    },
    "CSS": {
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": [
        "biome",
        "tailwindcss-intellisense-css",
        "tailwindcss-language-server",
        "!vscode-css-language-server"
      ]
    },
    "HTML": {
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": ["biome", "vscode-html-language-server", "tailwindcss-language-server"]
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": ["biome", "json-language-server"]
    },
    "JSONC": {
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": ["biome", "json-language-server"]
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      },
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": [
        "biome",
        "tsgo",
        "tailwindcss-language-server",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ]
    },
    "Markdown": {
      "soft_wrap": "editor_width"
    },
    "TypeScript": {
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      },
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": [
        "biome",
        "tsgo",
        "tailwindcss-language-server",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ]
    },
    "TSX": {
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      },
      "formatter": { "language_server": { "name": "biome" } },
      "language_servers": [
        "biome",
        "tsgo",
        "tailwindcss-language-server",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ]
    }
  },

  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "astro": "html"
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class:list=\"{([^}]*)}\"",
            "class:list='{([^}]*)}'"
          ]
        }
      }
    }
  }
}
