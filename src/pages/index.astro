---
import { getCollection } from 'astro:content'
import { ArrowUpRight } from 'lucide-react'

import Container from '@/components/Container.astro'
import { buttonVariants } from '@/components/ui/button'
import config from '@/config.json'
import Layout from '@/layouts/Base.astro'
import { filterDrafts, formatDate, withBase } from '@/lib/utils'

const posts = await getCollection('blog', (entry) => filterDrafts(entry))
const sortedPosts = posts
  .sort((a, b) => b.data.pubDate!.valueOf() - a.data.pubDate!.valueOf())
  .slice(0, 4)

const { title, description } = config.pages.find((item) => item.href === '/')!
---

<Layout title={title} description={description}>
  <Container class="mt-16">
    <header>
      <h1 class="text-4xl font-bold tracking-tighter text-foreground sm:text-5xl">
        Writing in public.
        <br />
        Building in private.
      </h1>
      <p class="mt-6 max-w-xl text-base leading-relaxed text-muted-foreground">
        {description}
      </p>
      <div class="mt-8 flex items-center gap-3">
        <a
          href={withBase('/blog')}
          class={buttonVariants({ size: 'lg', className: 'rounded-md px-4 shadow' })}
          data-astro-prefetch
        >
          Read the blog
        </a>
        <a
          href={withBase('/about')}
          class={buttonVariants({ variant: 'ghost', size: 'lg', className: 'group rounded-md px-4' })}
          data-astro-prefetch
        >
          About me
          <ArrowUpRight
            className="ml-1 h-4 w-4 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
          />
        </a>
      </div>
    </header>

    <hr class="my-16" />

    <section aria-labelledby="recent-heading">
      <div class="flex items-baseline justify-between">
        <h2
          id="recent-heading"
          class="text-2xl font-bold tracking-tighter text-foreground sm:text-3xl"
        >
          Recent posts
        </h2>
        <a
          href={withBase('/blog')}
          class="text-muted-foreground text-sm transition-colors hover:text-foreground"
          data-astro-prefetch
        >
          View all &rarr;
        </a>
      </div>

      <div class="mt-10 space-y-16 lg:border-l lg:pl-6">
        {
          sortedPosts.map((post) => {
            const { description: postDescription, title: postTitle, pubDate } = post.data
            return (
              <section class="lg:grid lg:grid-cols-[9rem_1fr] lg:gap-8 lg:items-baseline">
                <time
                  datetime={pubDate!.toISOString()}
                  class="hidden font-mono text-foreground/70 text-xs lg:block"
                >
                  {formatDate(pubDate!)}
                </time>
                <article>
                  <h2 class="text-base font-semibold tracking-tight text-foreground">
                    <a
                      href={withBase(`/blog/${post.id}`)}
                      class="hover:underline"
                      data-astro-prefetch
                    >
                      {postTitle}
                    </a>
                  </h2>
                  <p class="mt-1 text-muted-foreground text-sm">{postDescription}</p>
                  <time
                    datetime={pubDate!.toISOString()}
                    class="mt-2 block font-mono text-foreground/70 text-xs lg:hidden"
                  >
                    {formatDate(pubDate!)}
                  </time>
                </article>
              </section>
            )
          })
        }
      </div>
    </section>
  </Container>
</Layout>
