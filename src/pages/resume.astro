---
import Globe from 'lucide-static/icons/globe.svg'
import Mail from 'lucide-static/icons/mail.svg'
import MapPin from 'lucide-static/icons/map-pin.svg'

import Container from '@/components/Container.astro'
import { Badge } from '@/components/ui/badge'
import config from '@/config.json'
import GitHub from '@/icons/GitHub.svg'
import Layout from '@/layouts/Base.astro'

const { title, description } = config.pages.find((item) => item.href === '/resume')!
---

<Layout title={title} description={description}>
  <Container class="mt-16 print:mt-0">
    {/* Header */}
    <header>
      <h1 class="font-bold text-3xl tracking-tight">{config.name}</h1>
      <p class="mt-1 text-base text-muted-foreground">{config.resume.title}</p>
      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-muted-foreground text-sm">
        <span class="inline-flex items-center gap-1.5">
          <MapPin class="h-3.5 w-3.5" />
          {config.resume.location}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Mail class="h-3.5 w-3.5" />
          {config.email}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <GitHub class="h-3.5 w-3.5" />
          {`github.com/${config.github}`}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <Globe class="h-3.5 w-3.5" />
          {config.resume.website}
        </span>
      </div>
    </header>

    {/* Summary */}
    <p class="mt-6 text-foreground/80 text-sm leading-relaxed">{config.resume.summary}</p>

    <hr class="my-8" />

    {/* Experience */}
    <section>
      <h2 class="mb-4 font-semibold text-muted-foreground text-xs uppercase tracking-widest">
        Experience
      </h2>
      <div class="space-y-7">
        {
          config.resume.experience.map((job) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <h3 class="font-semibold text-base">
                  {job.role}
                  <span class="font-normal text-muted-foreground"> · </span>
                  <a
                    href={job.href}
                    target="_blank"
                    rel="noreferrer"
                    class="font-normal text-muted-foreground transition-colors hover:text-foreground hover:underline"
                  >
                    {job.company}
                  </a>
                </h3>
                <span class="font-medium text-muted-foreground text-sm">{job.period}</span>
              </div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <p class="text-muted-foreground text-sm italic">{job.context}</p>
                <span class="text-muted-foreground text-sm">{job.place}</span>
              </div>

              <ul class="mt-3 space-y-1.5">
                {job.points.map((p) => (
                  <li class="flex gap-2.5 text-foreground/80 text-sm leading-relaxed">
                    <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-muted-foreground/70" />
                    <span>{p}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-3 flex flex-wrap gap-1.5">
                {job.tech.map((t) => (
                  <Badge key={t} variant="secondary" className="font-normal">
                    {t}
                  </Badge>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <hr class="my-8" />

    {/* Projects */}
    <section>
      <h2 class="mb-4 font-semibold text-muted-foreground text-xs uppercase tracking-widest">
        Projects
      </h2>
      <div class="space-y-3.5">
        {
          config.resume.projects.map((project) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <h3 class="font-semibold text-sm">
                  <a
                    href={project.href}
                    target="_blank"
                    rel="noreferrer"
                    class="font-mono underline-offset-2 hover:underline"
                  >
                    {project.name}
                  </a>
                </h3>
                <span class="font-medium text-muted-foreground text-xs">{project.tag}</span>
              </div>
              <p class="mt-0.5 text-foreground/80 text-sm leading-relaxed">
                {project.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <hr class="my-8" />

    {/* Education */}
    <section>
      <h2 class="mb-4 font-semibold text-muted-foreground text-xs uppercase tracking-widest">
        Education
      </h2>
      <div class="space-y-3.5">
        {
          config.resume.education.map((education) => (
            <div>
              <div class="flex flex-wrap items-baseline justify-between gap-x-3">
                <h3 class="font-semibold text-base">
                  {education.degree}
                  <span class="font-normal text-muted-foreground"> · </span>
                  <a
                    href={education.href}
                    target="_blank"
                    rel="noreferrer"
                    class="font-normal text-muted-foreground transition-colors hover:text-foreground hover:underline"
                  >
                    {education.school}
                  </a>
                </h3>
                <span class="font-medium text-muted-foreground text-sm">{education.period}</span>
              </div>
              <p class="mt-1 text-muted-foreground text-sm">{education.details}</p>
            </div>
          ))
        }
      </div>
    </section>
  </Container>
</Layout>
