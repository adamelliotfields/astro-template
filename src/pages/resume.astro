---
import Container from '@/components/Container.astro'
import Component from '@/components/Resume.astro'
import config from '@/config.json'
import Layout from '@/layouts/Base.astro'

const { title, description } = config.pages.find((item) => item.href === '/resume')!
---

<Layout title={title} description={description}>
  <Container class="mt-16 print:mt-0">
    <Component />
  </Container>
</Layout>
